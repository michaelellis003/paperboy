# --- Remote access (required when serving HTTP / Cloud Run) ---
# Bearer token clients must present in the Authorization header.
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(32))'
MCP_AUTH_TOKEN=

# --- Delivery backend: "email" (Kindle, PocketBook, ...) or "dropbox" (Kobo) ---
DELIVERY_METHOD=email

# --- Email delivery ---
# Your device's intake address, e.g. you_xxxxxx@kindle.com from
# Amazon > Content & Devices > Preferences, or Send-to-PocketBook.
# KINDLE_EMAIL is accepted as an alias. (Left empty so setup_status
# reports honestly on partially filled files.)
DEVICE_EMAIL=
# This sender MUST be approved by the vendor (e.g. on Kindle's
# Approved Personal Document E-mail List)
FROM_EMAIL=

# SMTP credentials. For Gmail, create an App Password (not your real
# password): https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# --- Dropbox delivery (Kobo: link Dropbox on the device, papers sync in) ---
# Create a scoped app at https://www.dropbox.com/developers/apps with
# files.content.write, then obtain a refresh token via the OAuth flow.
# NOTE: Kobo devices only sync the fixed folder "Apps/Rakuten Kobo", so
# for a real Kobo choose "Full Dropbox" access when creating the app and
# set DROPBOX_FOLDER="/Apps/Rakuten Kobo". App-folder-scoped apps write
# to their own Apps/<app-name>/ sandbox, which the Kobo cannot see.
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_FOLDER=/Books

# --- Zotero (optional; enables queue_papers / send_queue) ---
# API key: https://www.zotero.org/settings/keys (needs library write access)
ZOTERO_API_KEY=
# Your userID is shown on the same settings page
ZOTERO_LIBRARY_ID=
ZOTERO_LIBRARY_TYPE=user
# Quote any value containing spaces (required for `source .env`)
READING_QUEUE_COLLECTION="Reading Queue"
SENT_TAG=sent-to-ereader

# --- Misc ---
# Contact email for OpenAlex/Unpaywall. Unpaywall REQUIRES one — with
# neither CONTACT_EMAIL nor FROM_EMAIL set (e.g. Dropbox-only setups),
# open-access PDF lookup for non-arXiv papers is disabled entirely.
# Falls back to FROM_EMAIL when unset.
CONTACT_EMAIL=
